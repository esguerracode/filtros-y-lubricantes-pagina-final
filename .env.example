# ============================================
# TELEGRAM - Notificaciones al administrador
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============================================
# TWILIO WHATSAPP - Notificaciones por WhatsApp
# ============================================
# Configuración de Twilio para enviar WhatsApp
# Obtén tus credenciales en: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Número de WhatsApp del cliente (para recibir notificaciones)
# Formato: 57 + número sin +
CLIENT_WHATSAPP=573143930345

# ============================================
# WOOCOMMERCE API (Si usas WordPress backend)
# ============================================
# VITE_WOOCOMMERCE_URL=https://tu-wordpress.com
# VITE_WOOCOMMERCE_CONSUMER_KEY=tu_consumer_key
# VITE_WOOCOMMERCE_CONSUMER_SECRET=tu_consumer_secret

